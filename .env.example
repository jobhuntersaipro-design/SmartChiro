# Neon PostgreSQL
DATABASE_URL="postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:pass@host.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth
AUTH_SECRET="replace-me"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (transactional email)
RESEND_API_KEY=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_MONTHLY=""

# Gemini
GEMINI_API_KEY=""

SKIP_EMAIL_VERIFICATION=false
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Seed
SEED_USER_EMAIL=
SEED_USER_PASSWORD=
SEED_USER_NAME=

# Appointment reminders
CRON_SECRET=replace-me
RESEND_REMINDERS_FROM=reminders@smartchiro.org

# WhatsApp worker (sibling repo: smartchiro-wa-worker)
WORKER_URL=https://wa-worker.example.com
WORKER_SHARED_SECRET=replace-me
WORKER_OUTBOUND_SECRET=replace-me
