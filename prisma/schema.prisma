generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  phoneNumber   String?

  isPro                Boolean  @default(false)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique

  activeBranchId String?

  accounts          Account[]
  sessions          Session[]
  branchMemberships BranchMember[]

  // Doctor profile (one-to-one, optional)
  doctorProfile DoctorProfile?

  // As doctor
  assignedPatients Patient[]      @relation("PatientDoctor")
  visits           Visit[]        @relation("VisitDoctor")
  appointments     Appointment[]  @relation("AppointmentDoctor")
  uploadedXrays    Xray[]         @relation("XrayUploader")
  annotations      Annotation[]   @relation("AnnotationCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───

enum BranchRole {
  OWNER
  ADMIN
  DOCTOR
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum XrayStatus {
  UPLOADING  // presigned URL generated, file not yet confirmed
  READY      // upload confirmed, available for annotation
  ARCHIVED   // soft-deleted / hidden from active views
}

enum BodyRegion {
  CERVICAL
  THORACIC
  LUMBAR
  PELVIS
  FULL_SPINE
  EXTREMITY
  OTHER
}

enum ViewType {
  AP       // anterior-posterior
  LATERAL
  OBLIQUE
  PA       // posterior-anterior
  OTHER
}

// ─── Organization ───

model Branch {
  id      String  @id @default(cuid())
  name    String
  address String?
  city    String?
  state   String?
  zip     String?
  phone   String?
  email   String?
  logo    String?

  // Practitioner / business
  ownerName       String?
  licenseNumber   String?  // Business license or NPI
  operatingHours  String?  // e.g. "Mon-Fri 9am-6pm"
  treatmentRooms  Int?
  clinicType      String?  // solo, group, franchise

  // Nice-to-have
  website             String?
  insuranceProviders   String?  // comma-separated
  specialties          String?  // comma-separated
  billingContactName   String?
  billingContactEmail  String?
  billingContactPhone  String?

  members      BranchMember[]
  patients     Patient[]
  appointments Appointment[]
  invoices     Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchMember {
  id   String     @id @default(cuid())
  role BranchRole @default(DOCTOR)

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@index([role])
}

// ─── Doctor Profile ───

model DoctorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional
  licenseNumber   String?
  specialties     String[]
  yearsExperience Int?
  education       String?

  // Clinic-Specific
  workingSchedule Json?
  treatmentRoom   String?
  consultationFee Decimal?

  // Optional
  bio            String?
  languages      String[]
  insurancePlans String[]

  // System
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Patient & Clinical ───

model Patient {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  email            String?
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?
  medicalHistory   String?
  notes            String?

  // New fields
  icNumber          String?
  occupation        String?
  race              String?
  maritalStatus     String?
  bloodType         String?
  allergies         String?
  referralSource    String?

  // Address breakdown
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?
  postcode          String?
  country           String?  @default("Malaysia")

  // Emergency contact breakdown
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Status
  status            String?  @default("active")

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Assigned to one doctor at a time
  doctorId String
  doctor   User @relation("PatientDoctor", fields: [doctorId], references: [id])

  visits       Visit[]
  xrays        Xray[]
  appointments Appointment[]
  invoices     Invoice[]
  documents    PatientDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([doctorId])
  @@index([lastName, firstName])
}

model Visit {
  id        String   @id @default(cuid())
  visitDate DateTime @default(now())

  // SOAP Notes
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  treatmentNotes String?

  patientId     String
  patient       Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId      String
  doctor        User @relation("VisitDoctor", fields: [doctorId], references: [id])

  appointmentId String? @unique

  xrays Xray[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
}

// ─── X-Ray & Annotations ───

model Xray {
  id         String      @id @default(cuid())
  title      String?
  bodyRegion BodyRegion?
  viewType   ViewType?
  status     XrayStatus  @default(UPLOADING)

  // Original upload
  fileUrl  String
  fileName String
  fileSize Int        // bytes
  mimeType String     // image/jpeg | image/png
  width    Int?       // px — set after upload confirmation
  height   Int?       // px

  // Thumbnail
  thumbnailUrl String?

  // Calibration
  isCalibrated    Boolean @default(false)
  pixelsPerMm     Float?    // computed from calibration reference
  calibrationNote String?   // e.g. "25mm coin" — what was used as reference

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User @relation("XrayUploader", fields: [uploadedById], references: [id])

  annotations Annotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([visitId])
  @@index([status])
  @@index([uploadedById])
}

model Annotation {
  id      String @id @default(cuid())
  label   String?
  version Int    @default(1)

  // Canvas state — the core payload
  canvasState     Json   // AnnotationCanvasState
  canvasStateSize Int    @default(0) // byte size of canvasState JSON (for quota tracking)

  // Snapshot
  thumbnailUrl String? // auto-generated preview after save

  // Image adjustment settings applied when this annotation was saved
  imageAdjustments Json? // ImageAdjustments

  // AI analysis results
  aiLandmarks    Json?
  aiMeasurements Json?

  xrayId String
  xray   Xray @relation(fields: [xrayId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User @relation("AnnotationCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([xrayId])
  @@index([createdById])
}

// ─── Appointments ───

model Appointment {
  id       String            @id @default(cuid())
  dateTime DateTime
  duration Int               @default(30)
  status   AppointmentStatus @default(SCHEDULED)
  notes    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   User @relation("AppointmentDoctor", fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([branchId])
  @@index([doctorId])
  @@index([dateTime])
  @@index([status])
}

// ─── Billing ───

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  amount        Decimal
  currency      String        @default("MYR")
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  lineItems     Json

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([branchId])
  @@index([status])
  @@index([invoiceNumber])
}

// ─── Documents ───

model PatientDocument {
  id       String  @id @default(cuid())
  title    String
  fileUrl  String
  fileName String
  fileSize Int
  mimeType String
  category String?

  patientId    String
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  uploadedById String

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([uploadedById])
}
