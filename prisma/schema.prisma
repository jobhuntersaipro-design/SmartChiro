generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  phoneNumber   String?

  isPro                Boolean @default(false)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  activeBranchId String?

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  branchMemberships   BranchMember[]

  // Doctor profile (one-to-one, optional)
  doctorProfile DoctorProfile?

  // As doctor
  assignedPatients Patient[]     @relation("PatientDoctor")
  visits           Visit[]       @relation("VisitDoctor")
  appointments     Appointment[] @relation("AppointmentDoctor")
  uploadedXrays    Xray[]        @relation("XrayUploader")
  annotations      Annotation[]  @relation("AnnotationCreator")
  xrayNotes        XrayNote[]    @relation("XrayNoteAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

// ─── Enums ───

enum BranchRole {
  OWNER
  ADMIN
  DOCTOR
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum XrayStatus {
  UPLOADING // presigned URL generated, file not yet confirmed
  READY // upload confirmed, available for annotation
  ARCHIVED // soft-deleted / hidden from active views
}

enum BodyRegion {
  CERVICAL
  THORACIC
  LUMBAR
  PELVIS
  FULL_SPINE
  EXTREMITY
  OTHER
}

enum ViewType {
  AP // anterior-posterior
  LATERAL
  OBLIQUE
  PA // posterior-anterior
  OTHER
}

enum ReminderChannel {
  WHATSAPP
  EMAIL
  BOTH
  NONE
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WaSessionStatus {
  DISCONNECTED
  PAIRING
  CONNECTED
  LOGGED_OUT
}

// ─── Organization ───

model Branch {
  id      String  @id @default(cuid())
  name    String
  address String?
  city    String?
  state   String?
  zip     String?
  phone   String?
  email   String?
  logo    String?

  // Practitioner / business
  ownerName      String?
  licenseNumber  String? // Business license or NPI
  operatingHours String? // e.g. "Mon-Fri 9am-6pm"
  treatmentRooms Int?
  clinicType     String? // solo, group, franchise

  // Nice-to-have
  website             String?
  insuranceProviders  String? // comma-separated
  specialties         String? // comma-separated
  billingContactName  String?
  billingContactEmail String?
  billingContactPhone String?

  members      BranchMember[]
  patients     Patient[]
  appointments Appointment[]
  invoices     Invoice[]

  reminderSettings BranchReminderSettings?
  waSession        WaSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchMember {
  id   String     @id @default(cuid())
  role BranchRole @default(DOCTOR)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@index([role])
}

// ─── Doctor Profile ───

model DoctorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional
  licenseNumber   String?
  specialties     String[]
  yearsExperience Int?
  education       String?

  // Clinic-Specific
  workingSchedule Json?
  treatmentRoom   String?
  consultationFee Decimal?

  // Optional
  bio            String?
  languages      String[]
  insurancePlans String[]

  // System
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Patient & Clinical ───

model Patient {
  id               String    @id @default(cuid())
  firstName        String
  lastName         String
  email            String?   @unique
  phone            String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?
  emergencyContact String?
  medicalHistory   String?
  notes            String?

  // New fields
  icNumber       String? @unique
  occupation     String?
  race           String?
  maritalStatus  String?
  bloodType      String?
  allergies      String?
  referralSource String?

  // Pricing (RM)
  initialTreatmentFee Float?
  firstTreatmentFee   Float?
  standardFollowUpFee Float?

  // Address breakdown
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postcode     String?
  country      String? @default("Malaysia")

  // Emergency contact breakdown
  emergencyName     String?
  emergencyPhone    String?
  emergencyRelation String?

  // Status
  status String? @default("active")

  // Reminder preferences
  reminderChannel   ReminderChannel @default(WHATSAPP)
  preferredLanguage String          @default("en") // "en" | "ms"

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Assigned to one doctor at a time
  doctorId String
  doctor   User   @relation("PatientDoctor", fields: [doctorId], references: [id])

  visits       Visit[]
  xrays        Xray[]
  appointments Appointment[]
  invoices     Invoice[]
  documents    PatientDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@index([doctorId])
  @@index([lastName, firstName])
}

model Visit {
  id        String   @id @default(cuid())
  visitDate DateTime @default(now())

  // Visit classification
  visitType      String? // "initial", "follow_up", "emergency", "reassessment", "discharge"
  chiefComplaint String? // Primary reason for this visit

  // SOAP Notes
  subjective     String?
  objective      String?
  assessment     String?
  plan           String?
  treatmentNotes String?

  // Clinical findings (structured)
  areasAdjusted       String? // Comma-separated: "C1, C5, T4, L5, SI"
  techniqueUsed       String? // "Gonstead", "Diversified", "Activator", "Thompson", etc.
  subluxationFindings String? // Specific subluxation patterns found

  // Vitals
  bloodPressureSys Int? // mmHg systolic
  bloodPressureDia Int? // mmHg diastolic
  heartRate        Int? // bpm
  weight           Float? // kg
  temperature      Float? // celsius

  // Recommendations
  recommendations String? // Home exercises, ergonomic advice, lifestyle changes
  referrals       String? // External referrals (orthopedist, neurologist, etc.)
  nextVisitDays   Int? // Recommended days until next visit

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   User   @relation("VisitDoctor", fields: [doctorId], references: [id])

  appointmentId String? @unique

  xrays         Xray[]
  questionnaire VisitQuestionnaire?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@index([visitType])
}

model VisitQuestionnaire {
  id String @id @default(cuid())

  // Recovery scores (0-10 scale)
  painLevel          Int // 0 = no pain, 10 = worst pain
  mobilityScore      Int // 0 = immobile, 10 = full range
  sleepQuality       Int // 0 = no sleep, 10 = perfect sleep
  dailyFunction      Int // 0 = cannot function, 10 = fully functional
  overallImprovement Int // 0 = much worse, 5 = same, 10 = fully recovered

  // Optional text
  patientComments String? // free-form patient feedback

  visitId String @unique
  visit   Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── X-Ray & Annotations ───

model Xray {
  id         String      @id @default(cuid())
  title      String?
  bodyRegion BodyRegion?
  viewType   ViewType?
  status     XrayStatus  @default(UPLOADING)

  // Original upload
  fileUrl  String
  fileName String
  fileSize Int // bytes
  mimeType String // image/jpeg | image/png
  width    Int? // px — set after upload confirmation
  height   Int? // px

  // Thumbnail
  thumbnailUrl String?

  // Calibration
  isCalibrated    Boolean @default(false)
  pixelsPerMm     Float? // computed from calibration reference
  calibrationNote String? // e.g. "25mm coin" — what was used as reference

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  visitId String?
  visit   Visit?  @relation(fields: [visitId], references: [id], onDelete: SetNull)

  uploadedById String
  uploadedBy   User   @relation("XrayUploader", fields: [uploadedById], references: [id])

  annotations Annotation[]
  notes       XrayNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([visitId])
  @@index([status])
  @@index([uploadedById])
}

model Annotation {
  id      String  @id @default(cuid())
  label   String?
  version Int     @default(1)

  // Canvas state — the core payload
  canvasState     Json // AnnotationCanvasState
  canvasStateSize Int  @default(0) // byte size of canvasState JSON (for quota tracking)

  // Snapshot
  thumbnailUrl String? // auto-generated preview after save

  // Image adjustment settings applied when this annotation was saved
  imageAdjustments Json? // ImageAdjustments

  // AI analysis results
  aiLandmarks    Json?
  aiMeasurements Json?

  xrayId String
  xray   Xray   @relation(fields: [xrayId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("AnnotationCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([xrayId])
  @@index([createdById])
}

model XrayNote {
  id     String @id @default(cuid())
  bodyMd String // markdown / plain text — rendered as plain text in MVP

  xrayId String
  xray   Xray   @relation(fields: [xrayId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("XrayNoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([xrayId, createdAt])
  @@index([authorId])
}

// ─── Appointments ───

model Appointment {
  id       String            @id @default(cuid())
  dateTime DateTime
  duration Int               @default(30)
  status   AppointmentStatus @default(SCHEDULED)
  notes    String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  doctorId String
  doctor   User   @relation("AppointmentDoctor", fields: [doctorId], references: [id])

  reminders AppointmentReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([branchId])
  @@index([doctorId])
  @@index([dateTime])
  @@index([status])
}

// ─── Billing ───

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  amount        Decimal
  currency      String        @default("MYR")
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  lineItems     Json

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([branchId])
  @@index([status])
  @@index([invoiceNumber])
}

// ─── Documents ───

model PatientDocument {
  id       String  @id @default(cuid())
  title    String
  fileUrl  String
  fileName String
  fileSize Int
  mimeType String
  category String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  uploadedById String

  createdAt DateTime @default(now())

  @@index([patientId])
  @@index([uploadedById])
}

// ─── Appointment Reminders ───

model BranchReminderSettings {
  id         String   @id @default(cuid())
  branchId   String   @unique
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  enabled    Boolean  @default(false)
  offsetsMin Int[]
  templates  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WaSession {
  id          String          @id @default(cuid())
  branchId    String          @unique
  branch      Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status      WaSessionStatus @default(DISCONNECTED)
  phoneNumber String?
  lastSeenAt  DateTime?
  qrPayload   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model AppointmentReminder {
  id            String          @id @default(cuid())
  appointmentId String
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channel       ReminderChannel
  offsetMin     Int
  scheduledFor  DateTime
  status        ReminderStatus  @default(PENDING)
  sentAt        DateTime?
  failureReason String?
  attemptCount  Int             @default(0)
  externalId    String?
  isFallback    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([appointmentId, channel, offsetMin, isFallback])
  @@index([scheduledFor, status])
  @@index([appointmentId])
}
